using estudo_poo_prova;

Produto notebook = new Produto("Notebook", 2500.00);
Produto mouse = new Produto("Mouse", 150.00);
Produto teclado = new Produto("Teclado", 300.00);
Pedido pedido = new Pedido();

pedido.AdicionarProduto(notebook);
pedido.AdicionarProduto(mouse);
pedido.AdicionarProduto(teclado);

pedido.CalcularValorTotal();
pedido.ListarProdutos();
